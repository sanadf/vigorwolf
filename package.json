{
  "name": "vigorwolf",
  "version": "1.0.0",
  "private": true,
  "description": "VIGORWOLF — premium dark streetwear / gymwear limited-drop store. Cloudflare Pages + Functions + D1.",
  "scripts": {
    "build": "echo 'VIGORWOLF is a static site served from public/ — no build step needed.'",
    "dev": "wrangler pages dev public --compatibility-date=2024-11-01 --compatibility-flags=nodejs_compat",
    "db:local": "wrangler d1 execute vigorwolf-db --local --file=./migrations/0001_init.sql",
    "db:remote": "wrangler d1 execute vigorwolf-db --remote --file=./migrations/0001_init.sql",
    "db:reset:local": "wrangler d1 execute vigorwolf-db --local --file=./migrations/0002_reset.sql && wrangler d1 execute vigorwolf-db --local --file=./migrations/0001_init.sql",
    "db:upgrade:local": "wrangler d1 execute vigorwolf-db --local --file=./migrations/0003_loyalty_coupons.sql",
    "db:upgrade:remote": "wrangler d1 execute vigorwolf-db --remote --file=./migrations/0003_loyalty_coupons.sql",
    "admin:reset:remote": "node scripts/reset-admin.mjs --remote",
    "admin:reset:local": "node scripts/reset-admin.mjs --local",
    "test:auth": "node scripts/test-auth.mjs",
    "test:reset": "node scripts/test-reset.mjs",
    "test:password-migration": "node scripts/test-password-migration.mjs",
    "test:promo": "node scripts/test-promo.mjs",
    "db:email-status:remote": "wrangler d1 execute vigorwolf-db --remote --file=./migrations/0005_email_status.sql",
    "db:email-status:local": "wrangler d1 execute vigorwolf-db --local --file=./migrations/0005_email_status.sql",
    "db:product-inventory:remote": "wrangler d1 execute vigorwolf-db --remote --file=./migrations/0006_product_inventory.sql",
    "db:product-inventory:local": "wrangler d1 execute vigorwolf-db --local --file=./migrations/0006_product_inventory.sql",
    "db:accounts:remote": "wrangler d1 execute vigorwolf-db --remote --file=./migrations/0007_user_accounts.sql",
    "db:accounts:local": "wrangler d1 execute vigorwolf-db --local --file=./migrations/0007_user_accounts.sql",
    "db:resets:remote": "wrangler d1 execute vigorwolf-db --remote --file=./migrations/0008_password_resets.sql",
    "db:resets:local": "wrangler d1 execute vigorwolf-db --local --file=./migrations/0008_password_resets.sql",
    "db:fix-auth:remote": "wrangler d1 execute vigorwolf-db --remote --file=./migrations/0009_fix_user_password_hash.sql",
    "db:fix-auth:local": "wrangler d1 execute vigorwolf-db --local --file=./migrations/0009_fix_user_password_hash.sql",
    "db:promo:remote": "wrangler d1 execute vigorwolf-db --remote --file=./migrations/0010_promo_and_delivery.sql",
    "db:promo:local": "wrangler d1 execute vigorwolf-db --local --file=./migrations/0010_promo_and_delivery.sql",
    "user:reset:remote": "node scripts/user-reset.mjs --remote",
    "user:reset:local": "node scripts/user-reset.mjs --local",
    "user:debug:remote": "node scripts/user-debug.mjs --remote",
    "user:debug:local": "node scripts/user-debug.mjs --local",
    "cleanup:resets:remote": "node scripts/cleanup-password-resets.mjs --remote",
    "cleanup:resets:local": "node scripts/cleanup-password-resets.mjs --local",
    "deploy": "wrangler pages deploy public"
  },
  "devDependencies": {
    "wrangler": "^4.107.0"
  }
}
